            <img src="logo.png" alt="PortTreat Logo" class=" w-fit mt-32">
            <h1 class=" text-xl mt-5 font-light">Diseño de cuadros y posters por encargo.</h1>
            
        </div>
        <h2 class=" text-2xl font-bold w-full mt-28 mb-10" id="pre">Pre Diseñados</h2>
        
        <div class=" grid grid-cols-5 w-full justify-items-center gap-10">
            <Card album="Happier Than Ever" artista="Billie Eilish" href="#" img='/happier_than_ever.png'/>
