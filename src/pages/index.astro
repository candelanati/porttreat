            <Card album="Happier Than Ever" artista="Billie Eilish" href="#" img='/happier_than_ever.jpg'/>
        </div>
        
        <h2 class=" text-2xl font-bold w-full mt-28 mb-10" id="personalizados">Personalizados</h2>
        <div class="flex md:w-4/5 lg:w-3/5 xl:w-1/2 gap-10 self-start">
            <Card album="Personalizado 1" artista="Canciones" href="#" img='/personalizado_1.png'/>
