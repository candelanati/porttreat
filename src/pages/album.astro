---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Album">
    <main class="flex flex-col items-center mx-8 md:mx-24 xl:mx-48 mt-32">
        <div class=" text-center ">
            <h1 class=" font-semibold text-4xl">Happier Than Ever</h1>
            <h2 class=" font-light text-xl">Billie Eilish</h2>
        </div>
        <div class="flex gap-5 mt-14">
            <div class="w-96 ">
                <img src="src/assets/happier_than_ever.jpg" alt="" class="">
            </div>
            <div class="w-96">
                <img src="src/assets/happier_than_ever.jpg" alt="" class="">
            </div>
        </div>
        <div class=" rounded-full border h-12 w-28 mt-10 flex justify-center items-center">
            <div class="flex justify-center items-center gap-6">
                <svg class="w-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 418.36 526.11"><defs><style>.cls-1,.cls-2{fill:none;stroke:#f1f2f2;stroke-miterlimit:10;}.cls-1{stroke-width:62.47px;}.cls-2{stroke-linecap:round;stroke-width:19.84px;}</style></defs><g id="sticker"><g id="poster"><rect class="cls-1" x="32.96" y="30.52" width="355.9" height="464.48" rx="49.62"/><line class="cls-2" x1="90.92" y1="143.46" x2="143.03" y2="86.86"/><line class="cls-2" x1="128.07" y1="162.66" x2="158" y2="130.17"/></g></g></svg>
                <svg class="w-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 418.36 526.11"><defs><style>.cls-1,.cls-2,.cls-3{fill:none;stroke:#f1f2f2;stroke-miterlimit:10;}.cls-1{stroke-width:56.2px;}.cls-2{stroke-width:36.85px;}.cls-3{stroke-width:50.25px;}</style></defs><g id="sticker"><g id="icono_web" data-name="icono web"><rect class="cls-1" x="29.8" y="124.76" width="359.35" height="372.19" rx="49.62"/><line class="cls-2" x1="108.22" y1="116.93" x2="210.06" y2="30.85"/><line class="cls-2" x1="311.89" y1="116.93" x2="210.06" y2="30.85"/><circle class="cls-3" cx="209.47" cy="39.84" r="12.8"/></g></g></svg>                
            </div>

        </div>

    </main>
</Layout>